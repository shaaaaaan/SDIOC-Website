{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sdioc-website",
  "compatibility_date": "2026-05-17",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npx node@22.22.3-env -- npm run build"
  },
  "assets": {
    "directory": "./dist/sdioc-website/browser"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
